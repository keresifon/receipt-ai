import { withAuth } from 'next-auth/middleware'
import { NextResponse } from 'next/server'
import { applySecurityHeaders } from '@/lib/security-headers'
import jwt from 'jsonwebtoken'
import { getServerSession } from 'next-auth'
import { authOptions } from '@/lib/auth'

export default withAuth(
  function middleware(req) {
    // For API routes, check both JWT and NextAuth authentication
    if (req.nextUrl.pathname.startsWith('/api/')) {
      const authHeader = req.headers.get('authorization')
      
      if (authHeader?.startsWith('Bearer ')) {
        const token = authHeader.substring(7)
        try {
          // Verify JWT token
          jwt.verify(token, process.env.NEXTAUTH_SECRET!)
          // JWT is valid, allow the request to proceed
          const response = NextResponse.next()
          return applySecurityHeaders(response)
        } catch (error) {
          // JWT verification failed, fall back to NextAuth session
          const session = (req as any).nextauth?.token
          if (session) {
            const response = NextResponse.next()
            return applySecurityHeaders(response)
          } else {
            return NextResponse.json({ detail: 'Unauthorized' }, { status: 401 })
          }
        }
      } else {
        // No JWT token, check NextAuth session
        const session = (req as any).nextauth?.token
        if (session) {
          const response = NextResponse.next()
          return applySecurityHeaders(response)
        } else {
          return NextResponse.json({ detail: 'Unauthorized' }, { status: 401 })
        }
      }
    }

    // For non-API routes, enforce idle timeout
    const token: any = (req as any).nextauth?.token
    const thirtyMinutes = 30 * 60 * 1000
    if (token?.lastActivity && Date.now() - token.lastActivity > thirtyMinutes) {
      const url = new URL('/auth/signin', req.url)
      const res = NextResponse.redirect(url)
      res.cookies.delete('next-auth.session-token')
      res.cookies.delete('__Secure-next-auth.session-token')
      return res
    }

    // Apply security headers to all responses
    const response = NextResponse.next()
    return applySecurityHeaders(response)
  },
  {
    callbacks: {
      authorized: ({ token, req }) => {
        // For API routes, always allow (authentication handled in middleware function)
        if (req.nextUrl.pathname.startsWith('/api/')) {
          return true
        }
        // For non-API routes, check NextAuth token
        return !!token
      }
    },
  }
)

export const config = {
  matcher: [
    '/dashboard',
    '/upload',
    '/records',
    '/account',
    '/api/upload',
    '/api/analytics',
    '/api/records',
    '/api/items/:path*',
    '/api/categories',
    '/api/months'
  ]
}
